<Window x:Class="Neo.PluginWindowWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Neo.PluginWindowWPF"
        mc:Ignorable="d"
        Title="MainWindow" WindowStyle="None" Width="0" Height="0">
    <Grid>
        <ContentControl x:Name="dynamicContent" />

        <Canvas x:Name="SelectionOverlay" IsHitTestVisible="False">
            <Border x:Name="SelectionBorder"
                    BorderBrush="#FF00A2FF"
                    BorderThickness="2"
                    CornerRadius="2"
                    Background="Transparent"
                    Visibility="Collapsed" />
        </Canvas>
    </Grid>
</Window>
