<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Neo.PluginWindowAvalonia.MainWindow"
        Title="NwCreatePluginWindowAvalonia" SystemDecorations="None" Width="0" Height="0">
<Grid>
        <ContentControl x:Name="dynamicContent" />

        <!-- Wait overlay: shown when no control is loaded -->
        <Border x:Name="WaitOverlay" Background="#F8F8F8" IsVisible="True">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <TextBlock Text="N.E.O." FontSize="32" FontWeight="Bold"
                           Foreground="#888" HorizontalAlignment="Center"/>
                <TextBlock x:Name="WaitStatusText" Text="Waiting for code..."
                           FontSize="16" Foreground="#AAA" HorizontalAlignment="Center"/>
                <TextBlock x:Name="WaitTimerText" Text=""
                           FontSize="22" FontFamily="Consolas, 'Cascadia Mono', monospace"
                           Foreground="#BBB" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Canvas x:Name="SelectionOverlay" IsHitTestVisible="False">
            <Border x:Name="SelectionBorder"
                    BorderBrush="#FF00A2FF"
                    BorderThickness="2"
                    CornerRadius="2"
                    Background="Transparent"
                    IsVisible="False" />
        </Canvas>
</Grid>
</Window>
