<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Neo.PluginWindowAvalonia.MainWindow"
        Title="NwCreatePluginWindowAvalonia" SystemDecorations="None" Width="0" Height="0">
<Grid>
        <ContentControl x:Name="dynamicContent" />

        <Canvas x:Name="SelectionOverlay" IsHitTestVisible="False">
            <Border x:Name="SelectionBorder"
                    BorderBrush="#FF00A2FF"
                    BorderThickness="2"
                    CornerRadius="2"
                    Background="Transparent"
                    IsVisible="False" />
        </Canvas>
</Grid>
</Window>
