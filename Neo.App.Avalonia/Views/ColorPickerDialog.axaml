<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cp="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
        x:Class="Neo.App.Views.ColorPickerDialog"
        Title="Pick a Color"
        Width="420" Height="520"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16" RowDefinitions="*,Auto">
        <cp:ColorView x:Name="ColorPicker" Grid.Row="0"
                       IsAlphaVisible="True"
                       IsColorSpectrumVisible="True"
                       IsColorComponentsVisible="True"
                       IsHexInputVisible="True"/>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Classes="rounded" Content="OK"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Click="Ok_Click"/>
            <Button Grid.Column="2" Classes="rounded" Content="Cancel"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
