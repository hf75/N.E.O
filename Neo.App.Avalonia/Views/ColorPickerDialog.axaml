<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Neo.App.Views.ColorPickerDialog"
        Title="Pick a Color"
        Width="380" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="16" Spacing="12">
        <ColorView x:Name="ColorPicker" IsAlphaVisible="True"
                   IsColorSpectrumVisible="True"
                   IsColorComponentsVisible="True"
                   IsHexInputVisible="True"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Classes="rounded" Content="OK"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Click="Ok_Click"/>
            <Button Grid.Column="2" Classes="rounded" Content="Cancel"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Click="Cancel_Click"/>
        </Grid>
    </StackPanel>
</Window>
