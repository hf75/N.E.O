<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:Neo.App;assembly=Neo.App.Core"
        x:Class="Neo.App.SettingsWindow"
        x:DataType="core:SettingsModel"
        Title="Settings"
        WindowStartupLocation="CenterOwner"
        FontFamily="Inter, Segoe UI, sans-serif"
        CanResize="False"
        SizeToContent="Height" MaxHeight="700" Width="450">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Margin="0,0,8,0"
                       Text="AI code generation attempts:"/>
            <TextBox Classes="rounded" Grid.Row="0" Grid.Column="1" x:Name="AttemptsTextBox"/>

            <!-- UseAvalonia is always true in the Avalonia host — no toggle needed -->
            <CheckBox Classes="rounded" Grid.Row="2" Content="Enable REACT-UI"
                      IsChecked="{Binding UseReactUi, Mode=TwoWay}" Margin="0,8,0,0"/>
            <CheckBox Classes="rounded" Grid.Row="3" Content="Enable Python"
                      IsChecked="{Binding UsePython, Mode=TwoWay}" Margin="0,8,0,0"/>
            <CheckBox Classes="rounded" Grid.Row="4" Content="Accept changes automatically"
                      IsChecked="{Binding AcceptAutomatic, Mode=TwoWay}" Margin="0,8,0,0"/>

            <!-- AI Models Section -->
            <Border Grid.ColumnSpan="2" Grid.Row="6" Margin="0,12,0,4"
                    BorderBrush="#DDD" BorderThickness="0,1,0,0"/>

            <StackPanel x:Name="RowClaudeModel" Grid.Row="7" Grid.ColumnSpan="2"
                        Margin="0,4,0,0" IsVisible="False">
                <TextBlock Text="Claude Model:" Margin="0,0,0,4"/>
                <ComboBox x:Name="ClaudeModelComboBox" Classes="rounded"/>
            </StackPanel>

            <StackPanel x:Name="RowOpenAiModel" Grid.Row="8" Grid.ColumnSpan="2"
                        Margin="0,4,0,0" IsVisible="False">
                <TextBlock Text="OpenAI Model:" Margin="0,0,0,4"/>
                <ComboBox x:Name="OpenAiModelComboBox" Classes="rounded"/>
            </StackPanel>

            <StackPanel x:Name="RowGeminiModel" Grid.Row="9" Grid.ColumnSpan="2"
                        Margin="0,4,0,0" IsVisible="False">
                <TextBlock Text="Gemini Model:" Margin="0,0,0,4"/>
                <ComboBox x:Name="GeminiModelComboBox" Classes="rounded"/>
            </StackPanel>

            <!-- Plugin Agent Models -->
            <ItemsControl x:Name="PluginAgentModelsPanel" Grid.Row="10" Grid.ColumnSpan="2"
                          Margin="0,4,0,0"/>

            <!-- Local Models -->
            <StackPanel x:Name="RowOllamaModel" Grid.Row="11" Grid.ColumnSpan="2"
                        Margin="0,4,0,0" IsVisible="False">
                <TextBlock Text="Ollama Model:" Margin="0,0,0,4"/>
                <ComboBox x:Name="OllamaModelComboBox" Classes="rounded" IsEditable="True"/>
            </StackPanel>

            <StackPanel x:Name="RowOllamaEndpoint" Grid.Row="12" Grid.ColumnSpan="2"
                        Margin="0,4,0,0" IsVisible="False">
                <TextBlock Text="Ollama Endpoint:" Margin="0,0,0,4"/>
                <TextBox x:Name="OllamaEndpointTextBox" Classes="rounded"/>
            </StackPanel>

            <StackPanel x:Name="RowLmStudioModel" Grid.Row="13" Grid.ColumnSpan="2"
                        Margin="0,4,0,0" IsVisible="False">
                <TextBlock Text="LM Studio Model:" Margin="0,0,0,4"/>
                <ComboBox x:Name="LmStudioModelComboBox" Classes="rounded" IsEditable="True"/>
            </StackPanel>

            <StackPanel x:Name="RowLmStudioEndpoint" Grid.Row="14" Grid.ColumnSpan="2"
                        Margin="0,4,0,0" IsVisible="False">
                <TextBlock Text="LM Studio Endpoint:" Margin="0,0,0,4"/>
                <TextBox x:Name="LmStudioEndpointTextBox" Classes="rounded"/>
            </StackPanel>

            <!-- AI Query Section -->
            <Border Grid.ColumnSpan="2" Grid.Row="15" Margin="0,12,0,4"
                    BorderBrush="#DDD" BorderThickness="0,1,0,0"/>

            <StackPanel x:Name="RowAIQueryProvider" Grid.Row="16" Grid.ColumnSpan="2"
                        Margin="0,4,0,0">
                <TextBlock Text="AI Query Provider (embedded):" Margin="0,0,0,4"/>
                <ComboBox x:Name="AIQueryProviderComboBox" Classes="rounded"
                          SelectionChanged="AIQueryProviderComboBox_SelectionChanged"/>
            </StackPanel>

            <StackPanel x:Name="RowAIQueryModel" Grid.Row="17" Grid.ColumnSpan="2"
                        Margin="0,4,0,0">
                <TextBlock Text="AI Query Model (embedded):" Margin="0,0,0,4"/>
                <ComboBox x:Name="AIQueryModelComboBox" Classes="rounded"/>
            </StackPanel>

            <Border Grid.ColumnSpan="2" Grid.Row="18" Margin="0,12,0,12"
                    BorderBrush="#DDD" BorderThickness="0,1,0,0"/>

            <Grid Grid.ColumnSpan="2" Grid.Row="19">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Classes="rounded" Grid.Column="0" Margin="0,0,8,0"
                        Click="ResetButton_Click" Content="Reset"/>
                <Button Classes="rounded" Grid.Column="1" Margin="0,0,8,0"
                        Click="OkButton_Click" Content="OK"/>
                <Button Classes="rounded" Grid.Column="2"
                        Click="CancelButton_Click" Content="Cancel"/>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
