<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Neo.App.DesignerPropertiesWindow"
        Title="Designer Properties"
        Width="380"
        SizeToContent="Height"
        MaxHeight="600"
        CanResize="False"
        Topmost="True"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,8">
            <TextBlock x:Name="HeaderText" FontSize="14" FontWeight="SemiBold"/>
            <TextBlock x:Name="SubheaderText" FontSize="11" Foreground="#6B7280"
                       TextWrapping="NoWrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Grid x:Name="RowText" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#374151" Text="Text"/>
                    <TextBox x:Name="TextValue" Grid.Column="1" MinHeight="32"
                             Classes="rounded"/>
                </Grid>

                <Grid x:Name="RowContent" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#374151" Text="Content"/>
                    <TextBox x:Name="ContentValue" Grid.Column="1" MinHeight="32"
                             Classes="rounded"/>
                </Grid>

                <Grid x:Name="RowFontFamily" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#374151" Text="Font"/>
                    <ComboBox x:Name="FontFamilyValue" Grid.Column="1" MinHeight="32"
                              Classes="rounded"/>
                </Grid>

                <Grid x:Name="RowFontSize" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#374151" Text="Size"/>
                    <ComboBox x:Name="FontSizeValue" Grid.Column="1" MinHeight="32"
                              Classes="rounded"/>
                </Grid>

                <Grid x:Name="RowFontWeight" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#374151" Text="Weight"/>
                    <ComboBox x:Name="FontWeightValue" Grid.Column="1" MinHeight="32"
                              Classes="rounded"/>
                </Grid>

                <Grid x:Name="RowFontStyle" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#374151" Text="Style"/>
                    <ComboBox x:Name="FontStyleValue" Grid.Column="1" MinHeight="32"
                              Classes="rounded"/>
                </Grid>

                <Grid x:Name="RowForeground" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#374151" Text="Foreground"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border x:Name="ForegroundPreview" Width="24" Height="24"
                                CornerRadius="6" BorderBrush="#D0D7DE" BorderThickness="1"
                                Background="Transparent" Margin="0,0,8,0"/>
                        <Button MinHeight="32" Classes="rounded" Padding="10,4"
                                Click="PickForeground_Click" Content="Pick..."/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="RowBackground" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#374151" Text="Background"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border x:Name="BackgroundPreview" Width="24" Height="24"
                                CornerRadius="6" BorderBrush="#D0D7DE" BorderThickness="1"
                                Background="Transparent" Margin="0,0,8,0"/>
                        <Button MinHeight="32" Classes="rounded" Padding="10,4"
                                Click="PickBackground_Click" Content="Pick..."/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="RowMargin" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#374151" Text="Margin"/>
                    <ComboBox x:Name="MarginValue" Grid.Column="1" MinHeight="32"
                              Classes="rounded"/>
                </Grid>

                <Grid x:Name="RowPadding">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#374151" Text="Padding"/>
                    <ComboBox x:Name="PaddingValue" Grid.Column="1" MinHeight="32"
                              Classes="rounded"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Width="92" Height="32" Classes="orange"
                    HorizontalContentAlignment="Center"
                    Click="Apply_Click" Content="Apply"/>
        </StackPanel>
    </Grid>
</Window>
