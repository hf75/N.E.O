<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Neo.App.SplashScreenWindow"
        Title="SplashScreenWindow" Height="320" Width="320"
        SystemDecorations="None"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False" Topmost="True"
        TransparencyLevelHint="Transparent"
        CanResize="False">
    <Grid Background="#01000000" PointerPressed="Grid_PointerPressed">
        <Ellipse Width="308" Height="308" Fill="Black"/>
        <Image Source="avares://Neo.App.Avalonia/Assets/logo3.png"
               Width="300" Height="300"
               Stretch="UniformToFill"
               HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image.Clip>
                <EllipseGeometry Center="150,150" RadiusX="150" RadiusY="150"/>
            </Image.Clip>
        </Image>
    </Grid>
</Window>
