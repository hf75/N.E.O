<Window x:Class="Neo.PluginWindowWPF.MCP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" WindowStyle="None" Width="0" Height="0">
    <Grid>
        <ContentControl x:Name="dynamicContent" />

        <!-- Wait overlay: shown when no control is loaded -->
        <Border x:Name="WaitOverlay" Background="#F8F8F8" Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="N.E.O." FontSize="32" FontWeight="Bold"
                           Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock x:Name="WaitStatusText" Text="Waiting for code..."
                           FontSize="16" Foreground="#FFAAAAAA" HorizontalAlignment="Center"/>
                <TextBlock x:Name="WaitTimerText" Text=""
                           FontSize="22" FontFamily="Consolas"
                           Foreground="#FFBBBBBB" HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>

        <Canvas x:Name="SelectionOverlay" IsHitTestVisible="False">
            <Border x:Name="SelectionBorder"
                    BorderBrush="#FF00A2FF"
                    BorderThickness="2"
                    CornerRadius="2"
                    Background="Transparent"
                    Visibility="Collapsed" />
        </Canvas>
    </Grid>
</Window>
