<Window x:Class="Neo.App.ProjectExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Project" FontFamily="Segoe UI Semilight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="520">
    <Border Padding="12" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
        <!-- Hauptlayout: Inhalte + Buttonleiste -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <!-- Inhalt -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Inhalt -->
            <DockPanel Grid.Row="0" LastChildFill="False">
                <TextBlock DockPanel.Dock="Top"
                           Margin="0 0 0 12"
                           Text="Project Export Settings"
                           FontSize="18"/>
                <StackPanel DockPanel.Dock="Top" Orientation="Vertical">
                    <!-- Basisverzeichnis -->
                    <TextBlock Text="Base Path:"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Style="{StaticResource RoundedTextBox}" x:Name="BasePathTextBox"
                                 Grid.Column="0"
                                 Margin="0 6 6 0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="OnInputChanged"/>
                        <Button Style="{StaticResource RoundedButton}" Grid.Column="1"
                                MinWidth="140"
                                Margin="0 6 0 0"
                                Padding="8 6"
                                Content="Browse …"
                                Click="BrowseFolder_Click">

                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="12"/>
                                </Style>
                            </Button.Resources>

                        </Button>
                    </Grid>

                    <!-- Projektname -->
                    <TextBlock Text="Project Name:" Margin="0,6,0,0"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" x:Name="ProjectNameTextBox"
                             Margin="0,6,0,0"
                             VerticalContentAlignment="Center"
                             TextChanged="OnInputChanged"/>

                    <!-- Pfad-Hinweis -->
                    <TextBlock x:Name="ProjectPathHintTextBlock"
                               Margin="0,12,0,6"
                               Foreground="Green"
                               FontSize="12"
                               FontStyle="Italic"
                               Text="The project path appears here."/>

                    <Grid Name="crossPlattformExport" Margin="0 0 0 6" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>                            
                        </Grid.RowDefinitions>
                        
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>                            
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Export Target:" Margin="0,6,0,6"/>

                        <RadioButton IsChecked="True" Name="targetWin" Grid.Row="1" Grid.Column="0" Content="Windows"></RadioButton>
                        <RadioButton Name="targetLinux" Grid.Column="1" Grid.Row="1" Content="Linux"></RadioButton>
                        <RadioButton Name="targetOSX" Grid.Column="2" Grid.Row="1" Content="OSX"></RadioButton>                        
                    </Grid>
                    
                    <!-- ICO File Upload -->
                    <TextBlock Text="Icon File (optional):" Margin="0,6,0,0"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label MinHeight="28" Margin="0 6 6 0" Style="{StaticResource RoundedTextLabel}" x:Name="IconFileNameTextBlock"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       FontStyle="Italic"/>

                        <Button Grid.Column="1" Style="{StaticResource RoundedButton}"
                                MinWidth="140"                                
                                Margin="0 6 0 0"
                                Padding="8 6"
                                Content="Load ICO …"
                                Click="LoadIcon_Click">

                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="12"/>
                                </Style>
                            </Button.Resources>

                        </Button>
                    </Grid>
                                       
                    <CheckBox Style="{StaticResource RoundedCheckBox}" Name="cbInstallDesktop" Margin="0,12,0,0" Content="Create Desktop Shortcut"></CheckBox>
                    <CheckBox Style="{StaticResource RoundedCheckBox}" Name="cbInstallStartMenu" Margin="0,6,0,0" Content="Create Startmenu Shortcut"></CheckBox>                    
                    
                    <!-- Modus -->
                    <TextBlock Text="Action when directory exists:" Margin="0,12,0,0"/>
                    <ComboBox Style="{StaticResource RoundedComboBox}" x:Name="CreationModeComboBox"
                              Margin="0,6,0,0"
                              Padding="6"
                              SelectionChanged="OnInputChanged">
                        <!-- Beispielwerte; gerne durch deine Binding-Quelle ersetzen -->
                        <ComboBoxItem Content="Cancel" IsSelected="True"/>
                        <ComboBoxItem Content="Overwrite"/>
                    </ComboBox>
                </StackPanel>
            </DockPanel>

            <!-- Buttonleiste -->
            <Border Grid.Row="1" Margin="0,16,0,0" BorderBrush="#22000000" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                <Grid Grid.Column="0" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="CancelButton" Style="{StaticResource RoundedButton}"
                                Margin="0, 0, 6, 0"
                                Padding="10 6"
                                Content="Cancel"
                                IsCancel="True"
                                Click="Cancel_Click" Cursor="Hand">

                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="1" x:Name="CreateButton" Style="{StaticResource RoundedButton}"
                                Margin="0, 0, 6, 0"
                                Padding="10 6"
                                Content="Export"
                                FontWeight="Bold"
                                IsDefault="True"
                                Click="ExportProject_Click"
                                IsEnabled="False">

                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>

                    </Button>

                    <Button Grid.Column="2" x:Name="SaveAsButton" Style="{StaticResource RoundedButton}"
                                Padding="10 6"
                                Content="Save as"
                                FontWeight="Bold"
                                IsDefault="True"
                                Click="SaveAsButton_Click"
                                IsEnabled="False" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>

                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
