<Window x:Class="Neo.App.DesignerPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Designer"
        Width="380"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        KeyDown="Window_KeyDown">
    <Border CornerRadius="14"
            Background="White"
            BorderBrush="#D0D7DE"
            BorderThickness="1"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       LastChildFill="false"
                       Margin="0,0,0,8"
                       Background="Transparent"
                       Cursor="SizeAll"
                       MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                    <TextBlock x:Name="HeaderText" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock x:Name="SubheaderText" FontSize="11" Foreground="#6B7280" TextWrapping="NoWrap" />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Width="30"
                        Height="30"
                        Margin="6,0,0,0"
                        Click="Close_Click"
                        ToolTip="Close"
                        Focusable="False"
                        Cursor="Arrow">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Bd"
                                    CornerRadius="15"
                                    Background="#F9FAFB"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1">
                                <Viewbox Width="12" Height="12" Stretch="Uniform">
                                    <Canvas Width="12" Height="12">
                                        <Path x:Name="Glyph"
                                              Data="M2,2 L10,10 M10,2 L2,10"
                                              Stroke="#6B7280"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#D0D7DE" />
                                    <Setter TargetName="Glyph" Property="Stroke" Value="#111827" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E5E7EB" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>

            <Border Grid.Row="1" Height="1" Background="#E5E7EB" Margin="0,0,0,10"/>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="360">
                <StackPanel>
                    <Grid x:Name="RowText" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#374151" Text="Text" />
                        <TextBox x:Name="TextValue" Grid.Column="1" MinHeight="32" Style="{StaticResource RoundedTextBox}" />
                    </Grid>

                    <Grid x:Name="RowContent" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#374151" Text="Content" />
                        <TextBox x:Name="ContentValue" Grid.Column="1" MinHeight="32" Style="{StaticResource RoundedTextBox}" />
                    </Grid>

                    <Grid x:Name="RowFontFamily" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#374151" Text="Font" />
                        <ComboBox x:Name="FontFamilyValue"
                                  Grid.Column="1"
                                  MinHeight="32"
                                  Style="{StaticResource RoundedComboBox}"
                                  IsEditable="False"
                                  IsTextSearchEnabled="True"
                                  DisplayMemberPath="Display"
                                  SelectedValuePath="Value" />
                    </Grid>

                    <Grid x:Name="RowFontSize" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#374151" Text="Size" />
                        <ComboBox x:Name="FontSizeValue"
                                  Grid.Column="1"
                                  MinHeight="32"
                                  Style="{StaticResource RoundedComboBox}"
                                  IsEditable="False"
                                  IsTextSearchEnabled="False"
                                  DisplayMemberPath="Display"
                                  SelectedValuePath="Value" />
                    </Grid>

                    <Grid x:Name="RowFontWeight" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#374151" Text="Weight" />
                        <ComboBox x:Name="FontWeightValue"
                                  Grid.Column="1"
                                  MinHeight="32"
                                  Style="{StaticResource RoundedComboBox}"
                                  IsEditable="False"
                                  IsTextSearchEnabled="False"
                                  DisplayMemberPath="Display"
                                  SelectedValuePath="Value" />
                    </Grid>

                    <Grid x:Name="RowFontStyle" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#374151" Text="Style" />
                        <ComboBox x:Name="FontStyleValue"
                                  Grid.Column="1"
                                  MinHeight="32"
                                  Style="{StaticResource RoundedComboBox}"
                                  IsEditable="False"
                                  IsTextSearchEnabled="False"
                                  DisplayMemberPath="Display"
                                  SelectedValuePath="Value" />
                    </Grid>

                    <Grid x:Name="RowForeground" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#374151" Text="Foreground" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="ForegroundPreview"
                                    Width="24"
                                    Height="24"
                                    CornerRadius="6"
                                    BorderBrush="#D0D7DE"
                                    BorderThickness="1"
                                    Background="Transparent"
                                    Margin="0,0,8,0" />
                            <Button MinHeight="32" Style="{StaticResource RoundedButton}" Padding="10,4" Click="PickForeground_Click" Content="Pick…" />
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="RowBackground" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#374151" Text="Background" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="BackgroundPreview"
                                    Width="24"
                                    Height="24"
                                    CornerRadius="6"
                                    BorderBrush="#D0D7DE"
                                    BorderThickness="1"
                                    Background="Transparent"
                                    Margin="0,0,8,0" />
                            <Button MinHeight="32" Style="{StaticResource RoundedButton}" Padding="10,4" Click="PickBackground_Click" Content="Pick…" />
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="RowMargin" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#374151" Text="Margin" />
                        <ComboBox x:Name="MarginValue"
                                  Grid.Column="1"
                                  MinHeight="32"
                                  Style="{StaticResource RoundedComboBox}"
                                  IsEditable="False"
                                  IsTextSearchEnabled="False"
                                  DisplayMemberPath="Display"
                                  SelectedValuePath="Value" />
                    </Grid>

                    <Grid x:Name="RowPadding">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#374151" Text="Padding" />
                        <ComboBox x:Name="PaddingValue"
                                  Grid.Column="1"
                                  MinHeight="32"
                                  Style="{StaticResource RoundedComboBox}"
                                  IsEditable="False"
                                  IsTextSearchEnabled="False"
                                  DisplayMemberPath="Display"
                                  SelectedValuePath="Value" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Width="92" Height="32" Style="{StaticResource RoundedOrangeButton}" Click="Apply_Click" Content="Apply" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
