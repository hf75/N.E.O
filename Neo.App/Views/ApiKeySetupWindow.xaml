<Window x:Class="Neo.App.Views.ApiKeySetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="N.E.O. — Setup"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI Semilight"
        ResizeMode="NoResize" SizeToContent="Height" Width="480"
        Background="White">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Welcome to N.E.O." FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="To get started, enter at least one API key." FontSize="13" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Anthropic Claude -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="Anthropic Claude" FontSize="13" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Hyperlink x:Name="LinkAnthropic" RequestNavigate="Hyperlink_RequestNavigate"
                               NavigateUri="https://console.anthropic.com/settings/keys">
                        Get a key &#x2192;
                    </Hyperlink>
                </TextBlock>
            </DockPanel>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="TxtAnthropic" Grid.Column="0" Padding="8,6" FontSize="13"
                             PasswordChanged="PasswordBox_PasswordChanged">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8,0,0,8"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
                <Button x:Name="BtnRevealAnthropic" Grid.Column="1" Content="&#xE7B3;" FontFamily="Segoe MDL2 Assets"
                        Width="32" FontSize="12" VerticalAlignment="Stretch"
                        Click="BtnReveal_Click" Tag="TxtAnthropic">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0,8,8,0"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>

        <!-- OpenAI -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="OpenAI" FontSize="13" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Hyperlink x:Name="LinkOpenAI" RequestNavigate="Hyperlink_RequestNavigate"
                               NavigateUri="https://platform.openai.com/api-keys">
                        Get a key &#x2192;
                    </Hyperlink>
                </TextBlock>
            </DockPanel>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="TxtOpenAI" Grid.Column="0" Padding="8,6" FontSize="13"
                             PasswordChanged="PasswordBox_PasswordChanged">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8,0,0,8"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
                <Button x:Name="BtnRevealOpenAI" Grid.Column="1" Content="&#xE7B3;" FontFamily="Segoe MDL2 Assets"
                        Width="32" FontSize="12" VerticalAlignment="Stretch"
                        Click="BtnReveal_Click" Tag="TxtOpenAI">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0,8,8,0"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>

        <!-- Google Gemini -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <DockPanel>
                <TextBlock Text="Google Gemini" FontSize="13" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Hyperlink x:Name="LinkGemini" RequestNavigate="Hyperlink_RequestNavigate"
                               NavigateUri="https://aistudio.google.com/apikey">
                        Get a key &#x2192;
                    </Hyperlink>
                </TextBlock>
            </DockPanel>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="TxtGemini" Grid.Column="0" Padding="8,6" FontSize="13"
                             PasswordChanged="PasswordBox_PasswordChanged">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8,0,0,8"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
                <Button x:Name="BtnRevealGemini" Grid.Column="1" Content="&#xE7B3;" FontFamily="Segoe MDL2 Assets"
                        Width="32" FontSize="12" VerticalAlignment="Stretch"
                        Click="BtnReveal_Click" Tag="TxtGemini">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0,8,8,0"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>

        <!-- Info text -->
        <TextBlock Grid.Row="5" Text="Keys are stored as Windows user environment variables and never leave your machine."
                   FontSize="11" Foreground="#999" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <!-- Local models hint -->
        <Border Grid.Row="6" Background="#F8F8F8" CornerRadius="8" Padding="12,8" Margin="0,0,0,20">
            <TextBlock FontSize="12" Foreground="#666" TextWrapping="Wrap">
                <Run FontWeight="SemiBold">No API key?</Run>
                <Run>You can also use local models with</Run>
                <Hyperlink NavigateUri="https://ollama.com" RequestNavigate="Hyperlink_RequestNavigate">Ollama</Hyperlink>
                <Run>or</Run>
                <Hyperlink NavigateUri="https://lmstudio.ai" RequestNavigate="Hyperlink_RequestNavigate">LM Studio</Hyperlink><Run>. Just start the server and restart N.E.O.</Run>
            </TextBlock>
        </Border>

        <!-- Buttons -->
        <DockPanel Grid.Row="7">
            <Button x:Name="BtnSkip" DockPanel.Dock="Right" Content="Skip" Padding="16,8"
                    Background="Transparent" BorderThickness="0" Foreground="#999" Cursor="Hand"
                    FontSize="13" Click="BtnSkip_Click" Margin="8,0,0,0"/>
            <Button x:Name="BtnSave" DockPanel.Dock="Right" Content="Save &amp; Start" Padding="20,8"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" IsEnabled="False"
                    Click="BtnSave_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="12"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="#999"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="True">
                                <Setter Property="Background" Value="#4A90E2"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <TextBlock/>
        </DockPanel>
    </Grid>
</Window>
