<UserControl x:Class="Neo.App.AiWaitIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Neo.App"
             Width="400"
             Height="400"
             Unloaded="UserControl_Unloaded"
             SnapsToDevicePixels="False"
             Background="Transparent"
             RenderOptions.BitmapScalingMode="HighQuality">

    <UserControl.Resources>

        <!-- Blob 1: light grey, slow heavy wobble -->
        <Storyboard x:Key="Blob1Anim" RepeatBehavior="Forever" AutoReverse="True" Timeline.DesiredFrameRate="60">
            <DoubleAnimation Storyboard.TargetName="Blob1Scale" Storyboard.TargetProperty="ScaleX"
                             From="0.85" To="1.15" Duration="0:0:3.3">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob1Scale" Storyboard.TargetProperty="ScaleY"
                             From="1.15" To="0.85" Duration="0:0:2.7">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob1Rotate" Storyboard.TargetProperty="Angle"
                             From="-35" To="40" Duration="0:0:4.5">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob1Translate" Storyboard.TargetProperty="X"
                             From="-18" To="22" Duration="0:0:3.9">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob1Translate" Storyboard.TargetProperty="Y"
                             From="15" To="-20" Duration="0:0:5.1">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Blob 2: medium grey, opposite phase -->
        <Storyboard x:Key="Blob2Anim" RepeatBehavior="Forever" AutoReverse="True" Timeline.DesiredFrameRate="60">
            <DoubleAnimation Storyboard.TargetName="Blob2Scale" Storyboard.TargetProperty="ScaleX"
                             From="1.12" To="0.88" Duration="0:0:2.5">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob2Scale" Storyboard.TargetProperty="ScaleY"
                             From="0.88" To="1.12" Duration="0:0:3.7">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob2Rotate" Storyboard.TargetProperty="Angle"
                             From="30" To="-45" Duration="0:0:5.3">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob2Translate" Storyboard.TargetProperty="X"
                             From="20" To="-16" Duration="0:0:4.1">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob2Translate" Storyboard.TargetProperty="Y"
                             From="-22" To="18" Duration="0:0:3.3">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Blob 3: dark grey, faster -->
        <Storyboard x:Key="Blob3Anim" RepeatBehavior="Forever" AutoReverse="True" Timeline.DesiredFrameRate="60">
            <DoubleAnimation Storyboard.TargetName="Blob3Scale" Storyboard.TargetProperty="ScaleX"
                             From="0.9" To="1.1" Duration="0:0:2.9">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob3Scale" Storyboard.TargetProperty="ScaleY"
                             From="1.1" To="0.9" Duration="0:0:2.1">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob3Rotate" Storyboard.TargetProperty="Angle"
                             From="-20" To="50" Duration="0:0:3.9">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob3Translate" Storyboard.TargetProperty="X"
                             From="15" To="-25" Duration="0:0:4.7">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob3Translate" Storyboard.TargetProperty="Y"
                             From="-12" To="24" Duration="0:0:2.5">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Blob 4: lightest grey accent, small & quick -->
        <Storyboard x:Key="Blob4Anim" RepeatBehavior="Forever" AutoReverse="True" Timeline.DesiredFrameRate="60">
            <DoubleAnimation Storyboard.TargetName="Blob4Scale" Storyboard.TargetProperty="ScaleX"
                             From="0.88" To="1.12" Duration="0:0:1.9">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob4Scale" Storyboard.TargetProperty="ScaleY"
                             From="1.12" To="0.88" Duration="0:0:2.3">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob4Rotate" Storyboard.TargetProperty="Angle"
                             From="40" To="-35" Duration="0:0:3.1">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob4Translate" Storyboard.TargetProperty="X"
                             From="-22" To="18" Duration="0:0:2.7">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Blob4Translate" Storyboard.TargetProperty="Y"
                             From="20" To="-15" Duration="0:0:3.5">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

    </UserControl.Resources>

    <Viewbox>
            <Grid Width="320" Height="320"
                  Background="Transparent"
                  TextOptions.TextFormattingMode="Ideal"
                  TextOptions.TextRenderingMode="Auto">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Blob area -->
                <Grid Grid.Row="0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      ClipToBounds="False">
                    <!-- Dither / halftone dot mask -->
                    <Grid.OpacityMask>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,5,5" ViewportUnits="Absolute"
                                      Viewbox="0,0,5,5" ViewboxUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="Black">
                                    <GeometryDrawing.Geometry>
                                        <EllipseGeometry Center="2.5,2.5" RadiusX="1.8" RadiusY="1.8"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Grid.OpacityMask>

                    <!-- Blob 1: light grey, offset top-left -->
                    <Ellipse Width="150" Height="150"
                             Opacity="0.7"
                             IsHitTestVisible="False"
                             Margin="-20,-18,0,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#C0C0C0" Offset="0.0" />
                                <GradientStop Color="#909090" Offset="0.6" />
                                <GradientStop Color="Transparent" Offset="1.0" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <BlurEffect Radius="16" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="Blob1Scale" CenterX="75" CenterY="75" />
                                <RotateTransform x:Name="Blob1Rotate" CenterX="75" CenterY="75" />
                                <TranslateTransform x:Name="Blob1Translate" />
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Blob 2: medium grey, offset bottom-right -->
                    <Ellipse Width="140" Height="140"
                             Opacity="0.6"
                             IsHitTestVisible="False"
                             Margin="18,20,0,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#8A8A8A" Offset="0.0" />
                                <GradientStop Color="#606060" Offset="0.6" />
                                <GradientStop Color="Transparent" Offset="1.0" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <BlurEffect Radius="14" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="Blob2Scale" CenterX="70" CenterY="70" />
                                <RotateTransform x:Name="Blob2Rotate" CenterX="70" CenterY="70" />
                                <TranslateTransform x:Name="Blob2Translate" />
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Blob 3: dark grey, offset top-right -->
                    <Ellipse Width="125" Height="125"
                             Opacity="0.55"
                             IsHitTestVisible="False"
                             Margin="16,-22,0,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#666666" Offset="0.0" />
                                <GradientStop Color="#404040" Offset="0.6" />
                                <GradientStop Color="Transparent" Offset="1.0" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <BlurEffect Radius="12" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="Blob3Scale" CenterX="62" CenterY="62" />
                                <RotateTransform x:Name="Blob3Rotate" CenterX="62" CenterY="62" />
                                <TranslateTransform x:Name="Blob3Translate" />
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Blob 4: lightest grey accent, offset bottom-left -->
                    <Ellipse Width="100" Height="100"
                             Opacity="0.5"
                             IsHitTestVisible="False"
                             Margin="-16,16,0,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#D0D0D0" Offset="0.0" />
                                <GradientStop Color="#A0A0A0" Offset="0.6" />
                                <GradientStop Color="Transparent" Offset="1.0" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <BlurEffect Radius="10" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="Blob4Scale" CenterX="50" CenterY="50" />
                                <RotateTransform x:Name="Blob4Rotate" CenterX="50" CenterY="50" />
                                <TranslateTransform x:Name="Blob4Translate" />
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                </Grid>

                <!-- Timer display (center, on top of blobs, outside dither mask) -->
                <TextBlock x:Name="TimerText"
                           Grid.Row="0"
                           Text="00:00.00"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Consolas"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1E1E2E" />

                <!-- Status text area -->
                <StackPanel Grid.Row="1"
                            Margin="0,20,0,8"
                            HorizontalAlignment="Center">

                    <TextBlock Text="{Binding Path=StatusText,
                                         RelativeSource={RelativeSource AncestorType={x:Type local:AiWaitIndicator}}}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="#444444"
                               FontFamily="Segoe UI"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />

                </StackPanel>
            </Grid>
    </Viewbox>
</UserControl>
