<Window x:Class="Neo.App.SettingsWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        WindowStartupLocation="CenterOwner" FontFamily="Segoe UI Semilight"
        ResizeMode="NoResize" SizeToContent="Height" Width="450">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- AI Models section -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Local models section (Ollama, LM Studio) -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- AI Query (embedded) section -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Divider + Buttons -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <TextBlock VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Margin="0, 0, 8, 0" Text="AI code generation attempts:"/>

        <TextBox Style="{StaticResource RoundedTextBox}" Grid.Row="0" Grid.Column="1" x:Name="AttemptsTextBox"
                         Text="{Binding AiCodeGenerationAttempts, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="AttemptsTextBox_PreviewTextInput"
                         DataObject.Pasting="AttemptsTextBox_Pasting"
                         ToolTip="Integers ≥ 1"></TextBox>

        <CheckBox Style="{StaticResource RoundedCheckBox}" Grid.Row="1" Content="Enable Avalonia" IsChecked="{Binding UseAvalonia, Mode=TwoWay}" Margin="0,8,0,0"/>
        <CheckBox Style="{StaticResource RoundedCheckBox}" Grid.Row="2" Content="Enable REACT-UI" IsChecked="{Binding UseReactUi, Mode=TwoWay}" Margin="0,8,0,0"/>
        <CheckBox Style="{StaticResource RoundedCheckBox}" Grid.Row="3" Content="Enable Python" IsChecked="{Binding UsePython, Mode=TwoWay}" Margin="0,8,0,0"/>
        <CheckBox Style="{StaticResource RoundedCheckBox}" Grid.Row="4" Content="Accept changes automatically" IsChecked="{Binding AcceptAutomatic, Mode=TwoWay}" Margin="0,8,0,0"/>

        <!-- AI Models Section -->
        <Border Grid.ColumnSpan="2" Grid.Row="6" Margin="0,12,0,4" BorderBrush="#DDD" BorderThickness="0,1,0,0"/>

        <StackPanel x:Name="RowClaudeModel" Grid.Row="7" Grid.ColumnSpan="2" Margin="0,4,0,0" Visibility="Collapsed">
            <TextBlock Text="Claude Model:" Margin="0,0,0,4"/>
            <ComboBox x:Name="ClaudeModelComboBox" Style="{StaticResource RoundedComboBox}"/>
        </StackPanel>

        <StackPanel x:Name="RowOpenAiModel" Grid.Row="8" Grid.ColumnSpan="2" Margin="0,4,0,0" Visibility="Collapsed">
            <TextBlock Text="OpenAI Model:" Margin="0,0,0,4"/>
            <ComboBox x:Name="OpenAiModelComboBox" Style="{StaticResource RoundedComboBox}"/>
        </StackPanel>

        <StackPanel x:Name="RowGeminiModel" Grid.Row="9" Grid.ColumnSpan="2" Margin="0,4,0,0" Visibility="Collapsed">
            <TextBlock Text="Gemini Model:" Margin="0,0,0,4"/>
            <ComboBox x:Name="GeminiModelComboBox" Style="{StaticResource RoundedComboBox}"/>
        </StackPanel>

        <!-- Local Models Section (Ollama, LM Studio) -->
        <StackPanel x:Name="RowOllamaModel" Grid.Row="10" Grid.ColumnSpan="2" Margin="0,4,0,0" Visibility="Collapsed">
            <TextBlock Text="Ollama Model:" Margin="0,0,0,4"/>
            <ComboBox x:Name="OllamaModelComboBox" Style="{StaticResource RoundedComboBox}" IsEditable="True"/>
        </StackPanel>

        <StackPanel x:Name="RowOllamaEndpoint" Grid.Row="11" Grid.ColumnSpan="2" Margin="0,4,0,0" Visibility="Collapsed">
            <TextBlock Text="Ollama Endpoint:" Margin="0,0,0,4"/>
            <TextBox x:Name="OllamaEndpointTextBox" Style="{StaticResource RoundedTextBox}"/>
        </StackPanel>

        <StackPanel x:Name="RowLmStudioModel" Grid.Row="12" Grid.ColumnSpan="2" Margin="0,4,0,0" Visibility="Collapsed">
            <TextBlock Text="LM Studio Model:" Margin="0,0,0,4"/>
            <ComboBox x:Name="LmStudioModelComboBox" Style="{StaticResource RoundedComboBox}" IsEditable="True"/>
        </StackPanel>

        <StackPanel x:Name="RowLmStudioEndpoint" Grid.Row="13" Grid.ColumnSpan="2" Margin="0,4,0,0" Visibility="Collapsed">
            <TextBlock Text="LM Studio Endpoint:" Margin="0,0,0,4"/>
            <TextBox x:Name="LmStudioEndpointTextBox" Style="{StaticResource RoundedTextBox}"/>
        </StackPanel>

        <!-- AI Query (embedded in generated apps) Section -->
        <Border Grid.ColumnSpan="2" Grid.Row="14" Margin="0,12,0,4" BorderBrush="#DDD" BorderThickness="0,1,0,0"/>

        <StackPanel x:Name="RowAIQueryProvider" Grid.Row="15" Grid.ColumnSpan="2" Margin="0,4,0,0">
            <TextBlock Text="AI Query Provider (embedded):" Margin="0,0,0,4"/>
            <ComboBox x:Name="AIQueryProviderComboBox" Style="{StaticResource RoundedComboBox}"
                      SelectionChanged="AIQueryProviderComboBox_SelectionChanged"/>
        </StackPanel>

        <StackPanel x:Name="RowAIQueryModel" Grid.Row="16" Grid.ColumnSpan="2" Margin="0,4,0,0">
            <TextBlock Text="AI Query Model (embedded):" Margin="0,0,0,4"/>
            <ComboBox x:Name="AIQueryModelComboBox" Style="{StaticResource RoundedComboBox}"/>
        </StackPanel>

        <Border Grid.ColumnSpan="2" Grid.Row="17" Margin="0,12,0,12" BorderBrush="#DDD" BorderThickness="0,1,0,0"/>

        <Grid Grid.ColumnSpan="2" Grid.Row="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Button Style="{StaticResource RoundedButton}" Grid.Column="0" Margin="0,0,8,0" Click="ResetButton_Click" Content="Reset">
            </Button>

            <Button Style="{StaticResource RoundedButton}" Grid.Column="1" Margin="0,0,8,0" IsDefault="True" Click="OkButton_Click" Content="OK">
            </Button>

            <Button Style="{StaticResource RoundedButton}" Grid.Column="2" IsCancel="True" Click="CancelButton_Click" Content="Cancel">
            </Button>
        </Grid>
    </Grid>
</Window>
