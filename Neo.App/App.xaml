<Application x:Class="Neo.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Neo.App">
    <Application.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>

            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                            CornerRadius="12"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="LightGray"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="LightGray"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedOrangeButton" TargetType="Button">
            <Setter Property="Background" Value="Orange"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="DarkOrange"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>

            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                            CornerRadius="12"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFA500"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF8C00"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <CornerRadius x:Key="InputCornerRadius">12</CornerRadius>
        <Thickness x:Key="InputPadding">4,2,4,2</Thickness>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <!-- Innere TextBox: transparent und ohne eigenen Rand -->
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="{StaticResource InputPadding}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <!-- ÄUSSERER BORDER: feste (oder separate) Werte, NICHT TemplateBinding -->
                        <Border x:Name="Chrome"
                            Background="White"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="{StaticResource InputCornerRadius}"
                            SnapsToDevicePixels="True">
                            <!-- Innere TextBox-Fläche / Caret / Scrollen -->
                            <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Fokus-Visual, ohne den Rand kaputt zu machen -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#4A90E2"/>
                                <!-- BorderThickness bleibt 1 -->
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#9AA7B2"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.6"/>
                            </Trigger>

                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#E74C3C"/>
                                <!-- BorderThickness bleibt 1 -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <CornerRadius x:Key="DisplayCornerRadius">12</CornerRadius>
        <Thickness   x:Key="DisplayPadding">8,4</Thickness>

        <Style x:Key="RoundedTextLabel" TargetType="Label">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="{StaticResource DisplayPadding}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Label">
                        <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource DisplayCornerRadius}"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <CornerRadius x:Key="DropdownCornerRadius">8</CornerRadius>

        <SolidColorBrush x:Key="InputBackground"      Color="White"/>
        <SolidColorBrush x:Key="InputBorderBrush"     Color="Gray"/>
        <SolidColorBrush x:Key="InputHoverBorder"     Color="#9AA7B2"/>
        <SolidColorBrush x:Key="InputFocusBorder"     Color="#4A90E2"/>
        <SolidColorBrush x:Key="DropdownBackground"   Color="White"/>
        <SolidColorBrush x:Key="DropdownBorderBrush"  Color="#DDDDDD"/>
        <SolidColorBrush x:Key="ItemHoverBackground"  Color="#F2F6FA"/>
        <SolidColorBrush x:Key="ItemSelectedBackground" Color="#EAF2FE"/>

        <!-- Item-Container: Einträge im Popup -->
        <Style x:Key="RoundedComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource DropdownCornerRadius}">
                            <ContentPresenter
                            Margin="6,2"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ItemHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ItemSelectedBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <!-- Defaults -->
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="{StaticResource InputPadding}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource RoundedComboBoxItem}"/>
            <Setter Property="MinHeight" Value="32"/>
            <!-- WICHTIG: Inhalt links, vertikal mittig -->
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <!-- Rahmen -->
                            <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource InputCornerRadius}"/>

                            <!-- Toggle steuert IsDropDownOpen -->
                            <ToggleButton x:Name="DropDownToggle"
              Background="Transparent"
              BorderThickness="0"
              Focusable="False"
              ClickMode="Press"
              HorizontalContentAlignment="Stretch"
              VerticalContentAlignment="Stretch"
              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">

                                <!-- Inhalt links, Pfeil rechts -->
                                <DockPanel Margin="{TemplateBinding Padding}" LastChildFill="True">
                                    <!-- Pfeil rechts -->
                                    <Border DockPanel.Dock="Right"
                Width="28"
                Margin="6,0,6,0"
                Background="Transparent">
                                        <Path x:Name="Arrow"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Data="M 0 0 L 4 4 L 8 0"
                  Stroke="{TemplateBinding Foreground}"
                  StrokeThickness="2"
                  Stretch="Uniform"/>
                                    </Border>

                                    <!-- Ausgewählter Inhalt füllt links -->
                                    <ContentPresenter x:Name="ContentSite"
                          Margin="0"
                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                          HorizontalAlignment="Left"
                          Content="{TemplateBinding SelectionBoxItem}"
                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                          RecognizesAccessKey="True"/>
                                </DockPanel>
                            </ToggleButton>


                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                                <Grid MaxHeight="320" SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder"
                                    Background="{StaticResource DropdownBackground}"
                                    BorderBrush="{StaticResource DropdownBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource DropdownCornerRadius}"
                                    Padding="4">
                                        <ScrollViewer CanContentScroll="True">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>

                        <!-- Zustände -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource InputFocusBorder}"/>
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource InputHoverBorder}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource InputFocusBorder}"/>
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter Property="ToolTip" Value="Dieses Style ist für nicht editierbare ComboBoxen gedacht."/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <CornerRadius x:Key="CheckCornerRadius">4</CornerRadius>
        <SolidColorBrush x:Key="CheckBoxBackground"        Color="White"/>
        <SolidColorBrush x:Key="CheckBoxBorder"            Color="Gray"/>
        <SolidColorBrush x:Key="CheckBoxHoverBorder"       Color="#9AA7B2"/>
        <SolidColorBrush x:Key="CheckBoxFocusBorder"       Color="#4A90E2"/>
        <SolidColorBrush x:Key="CheckBoxCheckedBackground" Color="#4A90E2"/>
        <SolidColorBrush x:Key="CheckBoxGlyph"             Color="White"/>

        <!-- RUND: CheckBox -->
        <Style x:Key="RoundedCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="{StaticResource CheckBoxBorder}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Die Box -->
                            <Border x:Name="Box"
                            Width="18" Height="18"
                            Background="{StaticResource CheckBoxBackground}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CheckCornerRadius}"
                            SnapsToDevicePixels="True"/>

                            <!-- Häkchen -->
                            <Path x:Name="Glyph"
                          Data="M 3 9 L 7 13 L 15 5"
                          Stroke="{StaticResource CheckBoxGlyph}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Visibility="Collapsed"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

                            <!-- Indeterminate-Strich -->
                            <Rectangle x:Name="IndeterminateMark"
                               Width="10" Height="2"
                               Fill="{StaticResource CheckBoxGlyph}"
                               RadiusX="1" RadiusY="1"
                               Visibility="Collapsed"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                            <!-- Beschriftung -->
                            <ContentPresenter Grid.Column="1"
                                      Margin="8,0,0,0"
                                      RecognizesAccessKey="True"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Grid>

                        <!-- Zustände -->
                        <ControlTemplate.Triggers>
                            <!-- Checked -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource CheckBoxCheckedBackground}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource CheckBoxCheckedBackground}"/>
                                <Setter TargetName="Glyph" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <!-- Indeterminate -->
                            <Trigger Property="IsThreeState" Value="True">
                                <Trigger.EnterActions/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="{x:Null}">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource CheckBoxBackground}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource CheckBoxFocusBorder}"/>
                                <Setter TargetName="IndeterminateMark" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource CheckBoxHoverBorder}"/>
                            </Trigger>

                            <!-- Fokus -->
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource CheckBoxFocusBorder}"/>
                                <Setter TargetName="Box" Property="BorderThickness" Value="2"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Box" Property="Opacity" Value="0.6"/>
                                <Setter Property="Foreground" Value="#80000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedPasswordBox" TargetType="PasswordBox">
            <!-- Innere PasswordBox: transparent & randlos -->
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="{StaticResource InputPadding}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <!-- ÄUSSERER, SICHTBARER RAHMEN (nicht an PasswordBox-BorderThickness binden) -->
                        <Border x:Name="Chrome"
                        Background="{StaticResource InputBackground}"
                        BorderBrush="{StaticResource InputBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource InputCornerRadius}"
                        SnapsToDevicePixels="True">
                            <!-- Pflicht: PART_ContentHost rendert den Inhalt/Caret -->
                            <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <!-- Zustände -->
                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource InputHoverBorder}"/>
                            </Trigger>

                            <!-- Fokus -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource InputFocusBorder}"/>
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="2"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <!-- Grundbreite für vertikale Scrollbar -->
            <Setter Property="Width" Value="12"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <!-- komplette Scrollbar-Fläche ist durchsichtig -->
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                           Orientation="{TemplateBinding Orientation}"
                           IsDirectionReversed="true">

                                <!-- UNSICHTBAR: Bereich vor dem Thumb -->
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsHitTestVisible="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" BorderThickness="0"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>

                                <!-- SICHTBAR: nur der Thumb -->
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb"
                                   Background="#66000000">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <!-- Pille, ohne zusätzlichen Rahmen -->
                                                <Border x:Name="ThumbBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Margin="0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>

                                <!-- UNSICHTBAR: Bereich nach dem Thumb -->
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.LineDownCommand}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsHitTestVisible="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" BorderThickness="0"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Vertikal: Pillen-Scrollbar rechts -->
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="12"/>
                            </Trigger>

                            <!-- Horizontal (falls mal auftaucht) -->
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="12"/>
                            </Trigger>

                            <!-- Hover: Thumb etwas deutlicher -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Background" Value="#88000000"/>
                            </Trigger>

                            <!-- Disabled: sehr dezent -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Thumb" Property="Background" Value="#22000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
